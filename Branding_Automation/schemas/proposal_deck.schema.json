{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proposal Deck Content",
  "type": "object",
  "required": [
    "deck_subtitle",
    "problem_statement",
    "proposed_solution",
    "scope_items",
    "timeline_phases",
    "investment_summary",
    "decision_and_cta"
  ],
  "properties": {
    "deck_subtitle": { "type": "string" },
    "problem_statement": { "type": "string" },
    "proposed_solution": { "type": "string" },
    "scope_items": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timeline_phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "window", "outcomes"],
        "properties": {
          "phase": { "type": "string" },
          "window": { "type": "string" },
          "outcomes": { "type": "string" }
        }
      }
    },
    "investment_summary": { "type": "string" },
    "decision_and_cta": { "type": "string" }
  }
}
