{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Invoice Template Content",
  "type": "object",
  "required": [
    "deck_subtitle",
    "invoice_number",
    "invoice_date",
    "due_date",
    "bill_to",
    "ship_to",
    "bill_from",
    "line_items",
    "subtotal",
    "discount",
    "subtotal_less_discount",
    "tax_rate",
    "total_tax",
    "shipping_handling",
    "balance_due",
    "payment_terms",
    "remarks"
  ],
  "properties": {
    "deck_subtitle": { "type": "string" },
    "invoice_number": { "type": "string" },
    "invoice_date": { "type": "string" },
    "due_date": { "type": "string" },
    "bill_to": { "type": "string" },
    "ship_to": { "type": "string" },
    "bill_from": { "type": "string" },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "quantity", "unit_price", "amount"],
        "properties": {
          "description": { "type": "string" },
          "quantity": { "type": "string" },
          "unit_price": { "type": "string" },
          "amount": { "type": "string" }
        }
      }
    },
    "subtotal": { "type": "string" },
    "discount": { "type": "string" },
    "subtotal_less_discount": { "type": "string" },
    "tax_rate": { "type": "string" },
    "total_tax": { "type": "string" },
    "shipping_handling": { "type": "string" },
    "balance_due": { "type": "string" },
    "payment_terms": { "type": "string" },
    "remarks": { "type": "string" }
  }
}
